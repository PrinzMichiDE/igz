// Prisma schema for Amazon affiliate comparison platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ArticleType {
  review
  comparison
  buying_guide
  advice_guide
}

enum ArticleStatus {
  draft
  published
  needs_review
}

enum Locale {
  de
  en
}

enum JobType {
  sync_search
  sync_details
  generate_review
  generate_comparison
  generate_comments
  generate_buying_guide
  generate_tech_profile
  generate_advice_guide
  generate_game_review
}

enum JobStatus {
  pending
  running
  succeeded
  failed
  skipped
}

enum ExperienceCommentStatus {
  pending
  published
  rejected
}

enum ProductTestRequestStatus {
  pending
  reviewed
  accepted
  declined
}

enum PriceAlertStatus {
  active
  triggered
  unsubscribed
  failed
}

model Category {
  id               String    @id @default(cuid())
  slug             String    @unique
  nameDe           String
  nameEn           String
  descriptionDe    String?
  descriptionEn    String?
  searchKeywords   String[]
  amazonCategoryId String?
  countryScope     String    @default("DE")
  imageUrl         String?
  imageData        Bytes?
  imageMimeType    String?
  imageFetchedAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  products    Product[]
  articles    Article[]
  comparisons Comparison[]
}

model Product {
  id             String    @id @default(cuid())
  asin           String
  country        String
  slug           String    @unique
  title          String
  ean            String?
  imageUrl       String?
  imageData      Bytes?
  imageMimeType  String?
  imageFetchedAt DateTime?
  price          Decimal?  @db.Decimal(10, 2)
  currency       String    @default("EUR")
  rating         Float?
  reviewCount    Int       @default(0)
  features       Json?
  productUrl     String?
  affiliateUrl   String?
  editorialScore Float?
  rawSearchJson  Json?
  rawDetailsJson Json?
  manualLinks    Json?
  /// Normalized bilingual technical datasheet for apples-to-apples comparisons
  specsJson      Json?
  /// Known product issues researched / synthesized with sources
  knownIssuesJson Json?
  /// Typical error/fault codes with remediation steps
  errorCodesJson Json?
  techProfileAt  DateTime?
  lastSyncedAt   DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  articles             Article[]
  experienceComments   ProductExperienceComment[]
  comparisonWins       Comparison[] @relation("WinnerProduct")
  comparisonPriceWins  Comparison[] @relation("PriceWinnerProduct")
  comparisonBudgetWins Comparison[] @relation("BudgetWinnerProduct")
  priceSnapshots       ProductPriceSnapshot[]
  priceAlerts          PriceAlert[]

  @@unique([asin, country])
  @@index([categoryId])
  @@index([ean])
}

model ProductExperienceComment {
  id            String                   @id @default(cuid())
  locale        Locale
  authorName    String
  authorContext String?
  authorEmail   String?
  rating        Int
  title         String?
  body          String
  usageWeeks    Int?
  verifiedStyle Boolean                  @default(true)
  source        String                   @default("openrouter_synth")
  status        ExperienceCommentStatus  @default(published)
  ipHash        String?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, locale, status])
  @@index([status, createdAt])
  @@index([ipHash, createdAt])
}

model Article {
  id             String        @id @default(cuid())
  type           ArticleType
  locale         Locale
  status         ArticleStatus @default(draft)
  title          String
  slug           String
  /// Stable topic identity for free-form Ratgeber / advice guides
  topicKey       String?
  excerpt        String?
  seoTitle       String?
  seoDescription String?
  contentJson    Json?
  bodyMarkdown   String?
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  productId  String?
  product    Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, type, locale])
  @@unique([categoryId, type, locale])
  @@unique([topicKey, locale])
  @@index([slug, locale])
  @@index([status])
  @@index([type, status, publishedAt])
}

model Comparison {
  id             String   @id @default(cuid())
  criteriaJson   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  winnerProductId String?
  winnerProduct   Product? @relation("WinnerProduct", fields: [winnerProductId], references: [id], onDelete: SetNull)
  priceWinnerId   String?
  priceWinner     Product? @relation("PriceWinnerProduct", fields: [priceWinnerId], references: [id], onDelete: SetNull)
  budgetWinnerId  String?
  budgetWinner    Product? @relation("BudgetWinnerProduct", fields: [budgetWinnerId], references: [id], onDelete: SetNull)

  @@unique([categoryId])
}

model JobRun {
  id           String    @id @default(cuid())
  type         JobType
  status       JobStatus @default(pending)
  message      String?
  error        String?
  requestsUsed Int       @default(0)
  metricsJson  Json?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())
}

model ApiQuotaMonth {
  id        String   @id @default(cuid())
  provider  String   @default("rapidapi_amazon")
  yearMonth String
  used      Int      @default(0)
  softLimit Int      @default(100)
  reserve   Int      @default(6)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([provider, yearMonth])
}

model AffiliateClick {
  id        String   @id @default(cuid())
  asin      String
  locale    Locale
  path      String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([asin])
  @@index([createdAt])
}

model ProductPriceSnapshot {
  id         String   @id @default(cuid())
  price      Decimal  @db.Decimal(10, 2)
  currency   String   @default("EUR")
  recordedAt DateTime @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, recordedAt])
}

/// Email opt-in when a product reaches a wish price.
model PriceAlert {
  id             String           @id @default(cuid())
  email          String
  locale         Locale
  targetPrice    Decimal          @db.Decimal(10, 2)
  currency       String           @default("EUR")
  status         PriceAlertStatus @default(active)
  unsubscribeToken String         @unique @default(cuid())
  lastNotifiedAt DateTime?
  triggeredAt    DateTime?
  ipHash         String?
  privacyAccepted Boolean         @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([status, productId])
  @@index([email, productId])
  @@index([ipHash, createdAt])
}

/// Reader / brand submissions suggesting a product for an IGZ test.
model ProductTestRequest {
  id              String                   @id @default(cuid())
  locale          Locale
  status          ProductTestRequestStatus @default(pending)
  name            String
  email           String
  company         String?
  productTitle    String
  amazonUrl       String?
  asin            String?
  categoryHint    String?
  message         String
  canShipSample   Boolean                  @default(false)
  privacyAccepted Boolean                  @default(false)
  ipHash          String?
  adminNote       String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([status, createdAt])
  @@index([ipHash, createdAt])
  @@index([email, createdAt])
}

/// Video game catalog entry sourced from IGDB (https://www.igdb.com/).
model Game {
  id               String    @id @default(cuid())
  igdbId           Int       @unique
  slug             String    @unique
  name             String
  summary          String?
  storyline        String?
  coverUrl         String?
  releaseDate      DateTime?
  igdbRating       Float?
  igdbRatingCount  Int?
  genresJson       Json?
  platformsJson    Json?
  developersJson   Json?
  publishersJson   Json?
  screenshotsJson  Json?
  videosJson       Json?
  websitesJson     Json?
  storeLinksJson   Json?
  rawIgdbJson      Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  reviews GameReview[]

  @@index([releaseDate])
  @@index([igdbRating])
  @@index([name])
}

/// Long-form AI game review (locale-specific), linked to a Game.
model GameReview {
  id             String        @id @default(cuid())
  locale         Locale
  status         ArticleStatus @default(draft)
  title          String
  slug           String
  excerpt        String?
  seoTitle       String?
  seoDescription String?
  contentJson    Json?
  overallScore   Float?
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  gameId String
  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, locale])
  @@unique([slug, locale])
  @@index([status, publishedAt])
  @@index([locale, status])
}

/// Immutable record of privileged admin actions for operational audit.
model AdminAuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  actorEmail  String
  detailsJson Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}
