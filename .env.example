# External Postgres – must be a REAL host (not "base" or "host").
# Do NOT use prisma+postgres:// (Accelerate) with the node-postgres adapter.
# On Vercel: prefer linking Storage → Postgres (injects POSTGRES_PRISMA_URL).
# If DATABASE_URL is a leftover placeholder, delete it or the app will fail.
#
# TLS:
# - Managed DB (Neon/Vercel/Supabase): sslmode=require (default on Vercel if unset)
# - Server without TLS: use sslmode=disable AND/OR DATABASE_SSL_MODE=disable
DATABASE_URL="postgresql://USER:PASSWORD@YOUR_REAL_HOST:5432/igz?sslmode=require"
# DATABASE_SSL_MODE=disable
# Vercel/Neon fallbacks (preferred over a stale DATABASE_URL):
# POSTGRES_PRISMA_URL=
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
# Optional overrides. For best editorial JSON reviews use a paid instruct model.
# If OPENROUTER_MODEL is a :free router, reviews stay on free (no silent paid upgrade).
OPENROUTER_REVIEW_MODEL=
OPENROUTER_FALLBACK_MODEL=

# RapidAPI Real-Time Amazon Data
RAPIDAPI_KEY=
RAPIDAPI_HOST=real-time-amazon-data.p.rapidapi.com
RAPIDAPI_MONTHLY_LIMIT=100
RAPIDAPI_MONTHLY_RESERVE=6

# Amazon Affiliate Tags (DE defaults to nerdiction-21 in code if empty)
AMAZON_PARTNER_TAG_DE=nerdiction-21
AMAZON_PARTNER_TAG_US=

# Auth
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Cron protection (required on Vercel). Vercel Cron sends Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=

# Optional HMAC secret for stored IP fingerprints (falls back to AUTH_SECRET).
IP_HASH_SECRET=

# App
NEXT_PUBLIC_SITE_NAME=IGZ Vergleich
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Search / Answer Engine discovery
INDEXNOW_KEY=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Upstash QStash / Workflow (keeps cron jobs under Vercel timeouts; ~500 msgs/day)
# Set these on Vercel too. Workflow steps live under /api/workflows/*
QSTASH_TOKEN=
QSTASH_URL=https://qstash-eu-central-1.upstash.io
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
# Public base URL used by Workflow callbacks (production site URL)
UPSTASH_WORKFLOW_URL=https://igz.vercel.app

# Upstash Redis (Vercel KV-compatible) – locks + light counters
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=

# Price alerts (optional – product page form stores alerts; emails need Resend)
RESEND_API_KEY=
EMAIL_FROM=IGZ Vergleich <noreply@igz.example.com>

# IGDB / Twitch (video game reviews) – https://api-docs.igdb.com/
# Create a Confidential Twitch app, then use Client ID + Client Secret here.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
