# External Postgres – must be postgresql://... (or postgres://...)
# Do NOT use prisma+postgres:// (Accelerate) for db push.
DATABASE_URL="postgresql://user:password@db.example.com:5432/igz?sslmode=require"
# Vercel Postgres / Neon fallbacks (used automatically when DATABASE_URL is
# missing, quoted, a placeholder, or an Accelerate URL):
# POSTGRES_PRISMA_URL=
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# RapidAPI Real-Time Amazon Data
RAPIDAPI_KEY=
RAPIDAPI_HOST=real-time-amazon-data.p.rapidapi.com
RAPIDAPI_MONTHLY_LIMIT=100
RAPIDAPI_MONTHLY_RESERVE=6

# Amazon Affiliate Tags
AMAZON_PARTNER_TAG_DE=
AMAZON_PARTNER_TAG_US=

# Auth
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# App
NEXT_PUBLIC_SITE_NAME=IGZ Vergleich
NEXT_PUBLIC_SITE_URL=http://localhost:3000
